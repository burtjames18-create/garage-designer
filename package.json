{
  "name": "garage-designer",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build --outDir dist",
    "preview": "vite preview --outDir dist",
    "electron:preview": "vite build && node electron/launcher.cjs",
    "electron:build": "vite build && electron-builder --win",
    "electron:publish": "vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.183.1",
    "electron-updater": "^6.8.3",
    "mdb-reader": "^3.2.0",
    "postprocessing": "^6.39.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.garageliving.designer",
    "productName": "Garage Living Designer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "burtjames18-create",
        "repo": "garage-designer"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@electron/asar": "^4.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
